#!/usr/bin/env bash
# Show Claude Code daily usage in tmux status bar.
# Requires ccusage and jq. Outputs nothing if either is missing.

CACHE="${XDG_RUNTIME_DIR:-/tmp}/claude-status.cache"
TTL=60

# Return cached result if fresh enough
if [[ -f "$CACHE" ]]; then
    age=$(( $(date +%s) - $(stat -c %Y "$CACHE") ))
    if [[ $age -lt $TTL ]]; then
        cat "$CACHE"
        exit 0
    fi
fi

# Find ccusage: check PATH, then mise shim, then mise node installs
find_ccusage() {
    if command -v ccusage &>/dev/null; then
        command -v ccusage
        return
    fi

    local shim="$HOME/.local/share/mise/shims/ccusage"
    if [[ -x "$shim" ]]; then
        echo "$shim"
        return
    fi

    local node_installs="$HOME/.local/share/mise/installs/node"
    if [[ -d "$node_installs" ]]; then
        for bin_dir in "$node_installs"/*/bin; do
            if [[ -x "$bin_dir/ccusage" ]]; then
                # Need node on PATH too for ccusage to run
                export _CCUSAGE_NODE_BIN="$bin_dir"
                echo "$bin_dir/ccusage"
                return
            fi
        done
    fi
}

ccusage_bin=$(find_ccusage)
[[ -z "$ccusage_bin" ]] && exit 0

# Add node to PATH if we found ccusage inside a mise node install
[[ -n "$_CCUSAGE_NODE_BIN" ]] && export PATH="$_CCUSAGE_NODE_BIN:$PATH"

# Get today's usage (--offline uses cached prices, skips network call)
json=$("$ccusage_bin" daily --json --offline 2>/dev/null)
[[ -z "$json" ]] && exit 0

# Format: "$1.23 | 4M tok"
today=$(printf '%s' "$json" | jq -r '
  .daily[-1] |
  "$\((.totalCost * 100 | round) / 100) | \(.totalTokens / 1000000 | floor)M tok"
' 2>/dev/null)
[[ -z "$today" ]] && exit 0

# Output to tmux and cache for next call
printf '%s' "$today" | tee "$CACHE"
